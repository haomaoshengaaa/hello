from pathlib import Path
import re

from pymatgen.io.vasp.outputs import Eigenval
from pymatgen.electronic_structure.core import Spin


def read_fermi_from_doscar(doscar_path="DOSCAR"):
    """
    Read the Fermi level from line 6 of DOSCAR.

    In a standard VASP DOSCAR, line 6 usually has the format:
        Emax Emin NEDOS Efermi weight
    """
    doscar_path = Path(doscar_path)

    with doscar_path.open("r") as f:
        lines = f.readlines()

    if len(lines) < 6:
        raise ValueError(f"{doscar_path} has fewer than 6 lines, cannot read Fermi level")

    sixth_line = lines[5].split()

    if len(sixth_line) < 4:
        raise ValueError(f"Unexpected format in line 6 of {doscar_path}: {lines[5]}")

    # In a standard VASP DOSCAR, the Fermi level is the 4th value on line 6.
    #
    # Example:
    # 102.19531148 -18.59170183 301 6.69598395 1.00000000
    # The Fermi level is 6.69598395, i.e. Python index 3.
    efermi = float(sixth_line[3])
    print(f"Found fermi level {efermi} in DOSCAR")

    return efermi


def get_parchg_state_energies(
    eigenval_path="pbe_calculation/EIGENVAL",
    doscar_path="DOSCAR",
    parchg_dir=".",
    spin=Spin.up,
):
    """
    Scan all PARCHG.????.???? files in parchg_dir and return the
    corresponding band/k-point energy information.

    Assumed file name format:
        PARCHG.0009.0001

    Here:
        0009 -> band index 9
        0001 -> k-point index 1

    Note:
        Band and k-point numbers in VASP-style file names are usually 1-based.
        Python array indices are 0-based, so we subtract 1.
    """

    eigenval = Eigenval(eigenval_path)

    num_spin = len(list(eigenval.eigenvalues.keys()))
    if num_spin == 2:
        raise ValueError(
            "Spin-polarized EIGENVAL detected: num_spin = 2. "
            "This script currently only supports non-spin-polarized calculations."
        )

    efermi = read_fermi_from_doscar(doscar_path)

    eigenvalues = eigenval.eigenvalues[spin]
    # shape: (nkpt, nbands, 2)
    # eigenvalues[k_index, band_index, 0] = eigenvalue
    # eigenvalues[k_index, band_index, 1] = occupation

    nkpt = eigenval.nkpt
    nbands = eigenval.nbands

    parchg_dir = Path(parchg_dir)

    pattern = re.compile(r"^PARCHG\.(\d+)\.(\d+)$")

    parchg_files = [
        file_path
        for file_path in sorted(parchg_dir.glob("PARCHG.*.*"))
        if pattern.match(file_path.name)
    ]

    if not parchg_files:
        raise FileNotFoundError(
            f"No PARCHG files matching 'PARCHG.<band>.<kpoint>' were found in {parchg_dir}"
        )

    results = []

    for file_path in parchg_files:
        match = pattern.match(file_path.name)

        band_number = int(match.group(1))
        kpt_number = int(match.group(2))

        band_index = band_number - 1
        kpt_index = kpt_number - 1

        if not (0 <= band_index < nbands):
            raise IndexError(
                f"{file_path.name}: band={band_number} is out of range. "
                f"EIGENVAL contains {nbands} bands"
            )

        if not (0 <= kpt_index < nkpt):
            raise IndexError(
                f"{file_path.name}: k-point={kpt_number} is out of range. "
                f"EIGENVAL contains {nkpt} k-points"
            )

        energy = eigenvalues[kpt_index, band_index, 0]
        occupation = eigenvalues[kpt_index, band_index, 1]

        energy_minus_fermi = energy - efermi

        results.append(
            {
                "file": str(file_path),
                "band": band_number,
                "kpoint": kpt_number,
                "energy": energy,
                "efermi": efermi,
                "energy_minus_fermi": energy_minus_fermi,
                "occupation": occupation,
            }
        )

    return results


results = get_parchg_state_energies(
    eigenval_path="../wavecar_prepare/EIGENVAL",
    doscar_path="../DOSCAR",
    parchg_dir=".",
    spin=Spin.up,
)

for r in results:
    print(
        f"{r['file']:20s} "
        f"band={r['band']:4d} "
        f"kpt={r['kpoint']:4d} "
        f"E-Ef={r['energy_minus_fermi']:12.6f} eV "
        f"occ={r['occupation']:.4f}"
    )
